rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: scanId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required) - Owner's UID
    //   - timestamp: number (required)
    //   - diseaseName: string (required)
    //   - confidenceScore: number (required)
    //   - organicTreatment: list (required)
    //   - sustainabilityTip: string (required)
    //   - imageUrl: string (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'diseaseName', 'confidenceScore', 'organicTreatment', 'sustainabilityTip', 'imageUrl']) &&
             data.userId == request.auth.uid &&
             data.timestamp is number &&
             data.diseaseName is string && data.diseaseName.size() < 100 &&
             data.confidenceScore is number && data.confidenceScore >= 0 && data.confidenceScore <= 1 &&
             data.organicTreatment is list && data.organicTreatment.size() < 20 &&
             data.sustainabilityTip is string && data.sustainabilityTip.size() < 1000 &&
             data.imageUrl is string && data.imageUrl.size() < 2000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is number;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              (request.auth.token.email == "cosmahke4@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /scans/{scanId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      allow update: if false; // Scans are immutable
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
